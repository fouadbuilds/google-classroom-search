{
  "manifest_version": 3,
  "name": "Google Classroom Search",
  "version": "0.1.0",
  "description": "A Chrome extension for Google Classroom with search functionality",
  "permissions": ["activeTab", "storage", "identity", "alarms"],
  "host_permissions": ["*://classroom.google.com/*", "https://script.google.com/*"],
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://classroom.google.com/*"],
      "js": ["src/content/content-script.js"],
      "type": "module"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "commands": {
    "activate-search": {
      "suggested_key": {
        "default": "Ctrl+K",
        "mac": "Command+K"
      },
      "description": "Activate search in Google Classroom"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
